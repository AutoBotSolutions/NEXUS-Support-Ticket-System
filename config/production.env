# NEXUS Production Environment Configuration
# Production environment variables for NEXUS Support System

# Application Configuration
NODE_ENV=production
PORT=3000
APP_VERSION=1.0.0

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/nexus-production
MONGODB_OPTIONS={"useNewUrlParser":true,"useUnifiedTopology":true}

# New Relic APM Configuration
NEW_RELIC_LICENSE_KEY=your_new_relic_license_key_here
NEW_RELIC_APP_NAME=NEXUS-Support-System
NEW_RELIC_AGENT_ENABLED=true
NEW_RELIC_LOG_LEVEL=info
NEW_RELIC_LOGGING_ENABLED=true
NEW_RELIC_LOG_FILE_PATH=/var/log/newrelic/newrelic.log
NEW_RELIC_BROWSER_MONITORING_ENABLED=true
NEW_RELIC_ERROR_COLLECTOR_ENABLED=true
NEW_RELIC_TRANSACTION_TRACER_ENABLED=true
NEW_RELIC_RECORD_SQL=true
NEW_RELIC_DISTRIBUTED_TRACING_ENABLED=true
NEW_RELIC_CUSTOM_INSIGHTS_ENABLED=true
NEW_RELIC_REAL_USER_MONITORING_ENABLED=true
NEW_RELIC_APPLICATION_LOGGING_ENABLED=true
NEW_RELIC_LOG_FORWARDING_ENABLED=true
NEW_RELIC_SLOW_SQL_ENABLED=true
NEW_RELIC_DATABASE_MONITORING_ENABLED=true
NEW_RELIC_SECURITY_ENABLED=true
NEW_RELIC_OBFUSCATE_SQL=true

# Security Configuration
JWT_SECRET=your_jwt_secret_key_here
BCRYPT_ROUNDS=12
SESSION_SECRET=your_session_secret_here
CORS_ORIGIN=https://your-production-domain.com

# Monitoring Configuration
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
GRAFANA_ENABLED=true
GRAFANA_PORT=3001
GRAFANA_ADMIN_PASSWORD=your_grafana_admin_password
ALERTMANAGER_ENABLED=true
ALERTMANAGER_PORT=9093

# Alerting Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_production_email@gmail.com
SMTP_PASSWORD=your_production_app_password
SMTP_FROM=alerts@nexus-support.com

# Slack Integration
SLACK_WEBHOOK_URL=your_production_slack_webhook_url
SLACK_CHANNEL=#nexus-alerts

# PagerDuty Integration
PAGERDUTY_INTEGRATION_KEY=your_pagerduty_integration_key
PAGERDUTY_SERVICE_KEY=your_pagerduty_service_key

# SMS Configuration (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Report Configuration
REPORT_WEBHOOK_URL=your_production_webhook_url
REPORT_WEBHOOK_TOKEN=your_production_webhook_token
REPORT_STORAGE_PATH=/var/log/nexus/reports
REPORT_RETENTION_DAYS=90

# Session Replay Configuration
SESSION_REPLAY_ENABLED=true
SESSION_REPLAY_SAMPLING_RATE=0.1
SESSION_REPLAY_MAX_SESSIONS=1000
SESSION_REPLAY_RETENTION_DAYS=30

# Vulnerability Scanning Configuration
VULNERABILITY_SCANNING_ENABLED=true
VULNERABILITY_SCAN_INTERVAL=86400000
VULNERABILITY_AUTO_REMEDIATION=false

# Threat Intelligence Configuration
THREAT_INTELLIGENCE_ENABLED=true
THREAT_INTELLIGENCE_UPDATE_INTERVAL=3600000
THREAT_INTELLIGENCE_FEEDS_ENABLED=true

# On-Call Configuration
ONCALL_ENABLED=true
ONCALL_AUTO_SCHEDULING=true
ONCALL_ESCALATION_ENABLED=true
ONCALL_NOTIFICATION_CHANNELS=email,slack,pagerduty

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE_PATH=/var/log/nexus/app.log
LOG_MAX_SIZE=100m
LOG_MAX_FILES=10
LOG_DATE_PATTERN=YYYY-MM-DD

# Performance Configuration
CLUSTER_MODE=true
CLUSTER_WORKERS=auto
REQUEST_TIMEOUT=30000
MAX_CONNECTIONS=1000
KEEP_ALIVE_TIMEOUT=65000

# Cache Configuration
REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0

# File Upload Configuration
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,application/pdf,text/plain
UPLOAD_PATH=/var/uploads/nexus

# Rate Limiting Configuration
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Health Check Configuration
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL=30000
HEALTH_CHECK_TIMEOUT=5000

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_INTERVAL=86400000
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=/var/backups/nexus

# SSL/TLS Configuration
SSL_ENABLED=true
SSL_CERT_PATH=/etc/ssl/certs/nexus.crt
SSL_KEY_PATH=/etc/ssl/private/nexus.key
SSL_CA_PATH=/etc/ssl/certs/ca.crt

# API Configuration
API_VERSION=v1
API_RATE_LIMIT=1000
API_TIMEOUT=30000
API_MAX_PAYLOAD=1048576

# Monitoring Endpoints Configuration
METRICS_ENDPOINT_ENABLED=true
HEALTH_ENDPOINT_ENABLED=true
DEBUG_ENDPOINT_ENABLED=false

# External Service Configuration
GITHUB_API_URL=https://api.github.com
GITHUB_TOKEN=your_github_token
GITHUB_TIMEOUT=10000

# Analytics Configuration
GOOGLE_ANALYTICS_ID=your_google_analytics_id
GOOGLE_TAG_MANAGER_ID=your_gtm_id

# CDN Configuration
CDN_ENABLED=true
CDN_URL=https://cdn.your-domain.com
CDN_CACHE_TTL=3600

# Content Security Policy
CSP_ENABLED=true
CSP_DIRECTIVES=default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' https:; connect-src 'self' https:; frame-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'

# Feature Flags
FEATURE_BETA_ENABLED=false
FEATURE_DEBUG_MODE=false
FEATURE_MAINTENANCE_MODE=false
FEATURE_NEW_UI_ENABLED=true

# Development/Debug Configuration (Production should be false)
DEBUG_MODE=false
VERBOSE_LOGGING=false
DEVELOPMENT_MODE=false

# Production Specific
PRODUCTION_MODE=true
ENVIRONMENT_CHECK_ENABLED=true
ERROR_REPORTING_ENABLED=true
PERFORMANCE_MONITORING_ENABLED=true
SECURITY_MONITORING_ENABLED=true

# Compliance Configuration
GDPR_COMPLIANCE=true
CCPA_COMPLIANCE=true
AUDIT_LOGGING_ENABLED=true
DATA_RETENTION_POLICY=365

# Infrastructure Configuration
INSTANCE_ID=auto
REGION=us-east-1
AVAILABILITY_ZONE=us-east-1a
AUTO_SCALING_GROUP=nexus-production
LOAD_BALANCER=nexus-lb

# Container Configuration
CONTAINER_MODE=false
KUBERNETES_ENABLED=false
DOCKER_COMPOSE_ENABLED=true

# Backup and Recovery
DISASTER_RECOVERY_ENABLED=true
BACKUP_ENCRYPTION=true
BACKUP_COMPRESSION=true
POINT_IN_TIME_RECOVERY=true
